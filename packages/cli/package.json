{
  "name": "create-polis-city",
  "version": "0.1.0",
  "description": "CLI scaffolder for Polis Protocol pop-up cities",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "create-polis-city": "./dist/index.js",
    "polis": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.0",
    "chalk": "^5.3.0",
    "citty": "^0.1.6",
    "degit": "^2.8.4"
  },
  "devDependencies": {
    "@polisprotocol/tsconfig": "workspace:*",
    "@types/degit": "^2.8.6",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
